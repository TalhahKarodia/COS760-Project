{
  "data": {
    "path": "data/raw/afrisenti_all_languages.csv",
    "text_col": "text",
    "label_col": "label",
    "language_col": "language",
    "test_size": 0.2,
    "val_size": 0.2,
    "random_state": 42
  },
  "bpe": {
    "vocab_size": 1000,
    "min_pair_frequency": 2,
    "max_length": 96
  },
  "model": {
    "embedding_dim": 128,
    "cnn_filters": 128,
    "kernel_size": 3,
    "lstm_hidden": 128,
    "dropout": 0.35,
    "batch_size": 64,
    "epochs": 10,
    "learning_rate": 0.001,
    "patience": 3
  },
  "baselines": {
    "max_features": 20000,
    "word_ngram_range": [1, 2],
    "char_ngram_range": [3, 5]
  },
  "output_dir": "results"
}
